generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum GameStatus {
  PLAYING
  COMPLETED
  ABANDONED
}

enum GameResult {
  WHITE_WIN
  BLACK_WIN
  DRAW
}

model User {
  id            String         @id @default(uuid())
  username      String?        @unique
  email         String         @unique
  password      String?        // Nullable because OAuth users might not have a password
  avatar        String?
  googleId      String?        @unique
  rating        Int            @default(200)
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  
  refreshTokens RefreshToken[]
  whiteGames    Game[]         @relation("WhitePlayer")
  blackGames    Game[]         @relation("BlackPlayer")
  wonGames      Game[]         @relation("Winner")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([userId])
  @@map("refresh_tokens")
}

model Game {
  id                  String      @id @default(uuid())
  roomId              String      @unique
  whitePlayerId       String
  whitePlayer         User        @relation("WhitePlayer", fields: [whitePlayerId], references: [id], onDelete: Cascade)
  whitePlayerUsername String
  blackPlayerId       String
  blackPlayer         User        @relation("BlackPlayer", fields: [blackPlayerId], references: [id], onDelete: Cascade)
  blackPlayerUsername String
  winnerId            String?
  winner              User?       @relation("Winner", fields: [winnerId], references: [id], onDelete: SetNull)
  result              GameResult?
  status              GameStatus  @default(PLAYING)
  reason              String?
  finalFen            String?
  pgn                 String?
  moves               Json        @default("[]")
  startedAt           DateTime    @default(now())
  endedAt             DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt

  @@index([whitePlayerId])
  @@index([blackPlayerId])
  @@index([winnerId])
  @@index([status])
  @@map("games")
}
